# ============ stormlead .env.example ============
# copy to .env, never commit .env
# ================================================

# --- postgres ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=stormlead
POSTGRES_USER=stormlead
POSTGRES_PASSWORD=change-me-in-openbao

# stormlead_core uses this single dsn (in-container; resolves to docker hostname)
DATABASE_URL=postgresql+psycopg://stormlead:change-me-in-openbao@postgres:5432/stormlead
DATABASE_URL_RO=postgresql+psycopg://stormlead_ro:change-me-ro@postgres:5432/stormlead

# host-side dsn for tools that run outside docker (alembic via `just migrate`,
# seed_dev.py, smoke_e2e.py). uses the host-mapped port from compose (5433).
DATABASE_URL_HOST=postgresql+psycopg://stormlead:change-me-in-openbao@localhost:5433/stormlead

# --- hatchet (durable workflows) ---
HATCHET_CLIENT_TOKEN=eyJhbGciOiJub25lIn0.eyJzdWIiOiJkZXYiLCJzZXJ2ZXJfdXJsIjoiaHR0cDovL2xvY2FsaG9zdDo4MDgwIiwiZ3JwY19icm9hZGNhc3RfYWRkcmVzcyI6ImxvY2FsaG9zdDo3MDc3In0.
HATCHET_CLIENT_TLS_STRATEGY=none
HATCHET_CLIENT_HOST_PORT=hatchet-engine:7077

# --- litellm (llm gateway) ---
# all runtime model calls go through this OpenAI-compatible proxy
LITELLM_PROXY_URL=http://litellm:4000
LITELLM_MASTER_KEY=sk-master-change-me
LITELLM_API_KEY=sk-stormlead-runtime

# services hold the *virtual* litellm key; only litellm holds the real upstream key
ANTHROPIC_API_KEY=sk-stormlead-runtime

# upstream provider key — *only* litellm reads this. covers all
# litellm routes including agent-default + bulk-offline (both haiku).
# add more provider keys here only when a route actually uses them.
ANTHROPIC_API_KEY_REAL=sk-ant-v4-change-me   # platform.claude.com

# --- langfuse (llm tracing) ---
# you pick these values — langfuse seeds itself with them on first boot
# via headless init (see compose's langfuse-web env block). agent-runtime
# + future llm-trace consumers read the same values from this .env.
# *first-boot only*: changing public/secret after the first run won't
# rotate the project's keys; do that via the langfuse ui then update here.
LANGFUSE_PUBLIC_KEY=pk-lf-stormlead-dev
LANGFUSE_SECRET_KEY=sk-lf-CHANGE-ME-32-chars-min-secret
LANGFUSE_HOST=http://langfuse-web:3000

# headless-init seed values (first boot only). leave defaults unless
# you know why you're changing them.
LANGFUSE_INIT_ORG_ID=stormlead
LANGFUSE_INIT_ORG_NAME=Stormlead
LANGFUSE_INIT_PROJECT_ID=stormlead-dev
LANGFUSE_INIT_PROJECT_NAME=stormlead-dev
LANGFUSE_INIT_USER_EMAIL=admin@stormlead.local
LANGFUSE_INIT_USER_NAME="Stormlead Admin"
LANGFUSE_INIT_USER_PASSWORD=CHANGE-ME-langfuse-admin-pwd

# --- s3 (hetzner object storage in prod; minio for offline local dev) ---
# prod: https://<bucket>.<region>.your-objectstorage.com  (~$5/mo, s3-compat)
# dev:  run minio single-binary if you need offline dev; otherwise point at a
#       hetzner dev bucket so you don't bake an extra service into compose.
S3_ENDPOINT=https://your-bucket.fsn1.your-objectstorage.com
S3_ACCESS_KEY=stormlead
S3_SECRET_KEY=change-me
S3_BUCKET_LEADS=leads-photos
S3_BUCKET_RECORDINGS=call-recordings
S3_BUCKET_BACKUPS=pgbackrest

# --- jambonz (telephony) ---
# jambonz lives in its own VM in prod. dev uses jambonz cloud free tier or mock
JAMBONZ_API_URL=http://jambonz-api:3000
JAMBONZ_API_KEY=change-me
JAMBONZ_ACCOUNT_SID=change-me
JAMBONZ_WEBHOOK_BASE=http://voice-bridge:8080

# --- formbricks ---
FORMBRICKS_WEBHOOK_SECRET=whsec_change-me

# --- twenty crm ---
TWENTY_API_URL=http://twenty:3000/graphql
TWENTY_API_KEY=change-me

# --- secrets ---
# openbao deferred until 2nd operator. v1 uses sops-encrypted .env.prod
# (age key in 1password / hardware token). see infra/openbao/README.md.

# --- nws / fema / nhc ---
NWS_USER_AGENT="stormlead/0.1 (ops@stormlead.example)"
FEMA_API_BASE=https://www.fema.gov/api/open/v2

# --- runtime ---
ENV=dev
LOG_LEVEL=INFO
SENTRY_DSN_GLITCHTIP=
