{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "stormlead": {
      "type": "local",
      "command": [
        "node",
        "tools/mcp/stormlead-local-ops.mjs"
      ],
      "enabled": true,
      "timeout": 300000
    },
    "docker": {
      "type": "local",
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run",
        "--profile",
        "stormlead_docker"
      ],
      "enabled": false,
      "timeout": 15000
    },
    "kubernetes": {
      "type": "local",
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run",
        "--profile",
        "stormlead_kubernetes"
      ],
      "enabled": false,
      "timeout": 15000
    }
  },
  "share": "disabled",
  "lsp": {
    "ruff": {
      "command": [
        "uv",
        "run",
        "ruff",
        "server"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    }
  },
  "formatter": {
    "ruff": {
      "command": [
        "uv",
        "run",
        "ruff",
        "format",
        "$FILE"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    }
  },
  "watcher": {
    "ignore": [
      ".git/**",
      "node_modules/**",
      ".opencode/node_modules/**",
      ".venv/**",
      "**/__pycache__/**",
      "**/.pytest_cache/**",
      ".mypy_cache/**",
      ".ruff_cache/**",
      "coverage/**",
      "dist/**",
      "build/**",
      "testing/.pytest_cache/**",
      "testing/playwright-report/**",
      "testing/artifacts/**",
      "testing/screenshots/**"
    ]
  }
}
