{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "docker": {
      "type": "local",
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run",
        "--profile",
        "stormlead_docker"
      ],
      "enabled": true,
      "timeout": 15000
    },
    "kubernetes": {
      "type": "local",
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run",
        "--profile",
        "stormlead_kubernetes"
      ],
      "enabled": true,
      "timeout": 15000
    }
  }
}
